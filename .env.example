NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPER_ADMIN_EMAILS=superadmin@empresa.com
# Nome gravado em public.auditores ao provisionar o super admin (opcional)
# SUPER_ADMIN_NOME=Thales Silva
# Segredo para POST /api/admin/bootstrap-super-admins (promove e-mails a super_admin no Auth)
SUPABASE_BOOTSTRAP_SECRET=generate-a-long-random-string
# Senha inicial para POST /api/admin/provision-super-admin (criar usuário apagado no Auth)
SUPER_ADMIN_INITIAL_PASSWORD=min-8-chars
# Se true, provision também redefine a senha quando o usuário já existir
# SUPER_ADMIN_RESET_PASSWORD=true
